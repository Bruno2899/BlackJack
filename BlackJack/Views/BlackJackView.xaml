<UserControl x:Class="BlackJack.Views.BlackjackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="600"
             Width="1000"
             Background="DarkGreen">

	<Grid>

		<StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

			<TextBlock Text="BLACKJACK"
                       FontSize="32"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

			<TextBlock Text="Spiel läuft..."
                       FontSize="20"
                       Foreground="White"
                       Margin="0,20,0,20"
                       HorizontalAlignment="Center"/>

			<StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

				<Button Content="Hit"
                        Width="120"
                        Height="50"
                        Margin="10"/>

				<Button Content="Stand"
                        Width="120"
                        Height="50"
                        Margin="10"/>

				<Button Content="Back"
                        Width="120"
                        Height="50"
                        Margin="10"/>

			</StackPanel>

		</StackPanel>

	</Grid>

</UserControl>