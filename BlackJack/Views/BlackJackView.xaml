<UserControl x:Class="BlackJack.Views.BlackjackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="DarkGreen"
             MinWidth="1000"
             MinHeight="600">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        HorizontalAlignment="Left">

                <TextBlock Text="Guthaben"
                           FontSize="20"
                           Foreground="White"/>

                <TextBlock Text="{Binding Guthaben}"
                           FontSize="28"
                           Foreground="Gold"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right">

                <TextBlock Text="Einsatz"
                           FontSize="20"
                           Foreground="White"/>

                <TextBlock Text="{Binding Einsatz}"
                           FontSize="28"
                           Foreground="Gold"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center">

                <TextBlock Text="Dealer"
                           FontSize="30"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding DealerKarten}"
                           FontSize="28"
                           Foreground="White"
                           Margin="0,20,0,10"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding DealerKartenAufdecken}"
                           FontSize="36"
                           Foreground="Yellow"
                           HorizontalAlignment="Center"/>

            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="{Binding SpielStatus}"
                       FontSize="28"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,20"/>

            
            <StackPanel Grid.Row="2"
                        VerticalAlignment="Center">

                <TextBlock Text="{Binding SpielerPunkte}"
                           FontSize="36"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding SpielerKarten}"
                           FontSize="28"
                           Foreground="White"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Grid>


        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Center"
                   Margin="0,30">

            <Button Content="Hit"
                    MinWidth="120"
                    Height="50"
                    Margin="5"
                    Command="{Binding HitCommand}"/>

            <Button Content="Stand"
                    MinWidth="120"
                    Height="50"
                    Margin="5"
                    Command="{Binding StandCommand}"/>

            <Button Content="Neue Runde"
                    MinWidth="140"
                    Height="50"
                    Margin="5"
                    Command="{Binding NeueRundeCommand}"/>

            <Button Content="Einsatz"
                    MinWidth="120"
                    Height="50"
                    Margin="5"
                    Command="{Binding EinsatzMenueCommand}"/>

            <Button Content="Back"
                    MinWidth="100"
                    Height="50"
                    Margin="5"
                    Command="{Binding BackCommand}"/>

        </WrapPanel>

        
        <StackPanel Grid.Row="3"
                    Visibility="{Binding EinsatzButtonsSichtbar,
                    Converter={StaticResource BoolToVisibility}}">

            <WrapPanel HorizontalAlignment="Center">

                <Button Content="+1" Width="80" Margin="2" Command="{Binding Plus1Command}"/>
                <Button Content="+5" Width="80" Margin="2" Command="{Binding Plus5Command}"/>
                <Button Content="+20" Width="80" Margin="2" Command="{Binding Plus20Command}"/>
                <Button Content="+100" Width="80" Margin="2" Command="{Binding Plus100Command}"/>
                <Button Content="+250" Width="80" Margin="2" Command="{Binding Plus250Command}"/>
                <Button Content="+1000" Width="80" Margin="2" Command="{Binding Plus1000Command}"/>
                <Button Content="+5000" Width="80" Margin="2" Command="{Binding Plus5000Command}"/>
                <Button Content="+10000" Width="80" Margin="2" Command="{Binding Plus10000Command}"/>

            </WrapPanel>

            <WrapPanel HorizontalAlignment="Center">

                <Button Content="-1" Width="80" Margin="2" Command="{Binding Minus1Command}"/>
                <Button Content="-5" Width="80" Margin="2" Command="{Binding Minus5Command}"/>
                <Button Content="-20" Width="80" Margin="2" Command="{Binding Minus20Command}"/>
                <Button Content="-100" Width="80" Margin="2" Command="{Binding Minus100Command}"/>
                <Button Content="-250" Width="80" Margin="2" Command="{Binding Minus250Command}"/>
                <Button Content="-1000" Width="80" Margin="2" Command="{Binding Minus1000Command}"/>
                <Button Content="-5000" Width="80" Margin="2" Command="{Binding Minus5000Command}"/>
                <Button Content="-10000" Width="80" Margin="2" Command="{Binding Minus10000Command}"/>

            </WrapPanel>

        </StackPanel>

    </Grid>

</UserControl>