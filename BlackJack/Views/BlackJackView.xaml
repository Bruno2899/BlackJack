<UserControl x:Class="BlackJack.Views.BlackjackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="600"
             Width="1000"
             Background="DarkGreen">

    <Grid>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="BLACKJACK"
                       FontSize="32"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Dealer"
           FontSize="24"
           Foreground="White"
           HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding DealerKarten}"
           FontSize="20"
           Foreground="White"
           Margin="0,10,0,30"
           HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding DealerPunkte}"
           FontSize="22"
           Foreground="Yellow"
           HorizontalAlignment="Center"
           Margin="0,10,0,20"/>
            <TextBlock Text="Spiel läuft..."
                       FontSize="20"
                       Foreground="White"
                       Margin="0,20,0,20"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding SpielerPunkte}"
           FontSize="20"
           Foreground="White"/>
            <TextBlock Text="{Binding SpielerKarten}"
           FontSize="20"
           Foreground="White"
           Margin="0,20,0,20"
           HorizontalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Hit"
                        Width="120"
                        Height="50"
                        Margin="10"
                        Command="{Binding HitCommand}"/>

                <Button Content="Stand"
                        Width="120"
                        Height="50"
                        Margin="10"
                        Command="{Binding StandCommand}"/>

                <Button Content="Back"
                        Width="120"
                        Height="50"
                        Margin="10"
                        Command="{Binding BackCommand}"/>

            </StackPanel>

        </StackPanel>

    </Grid>

</UserControl>