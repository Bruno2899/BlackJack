<UserControl x:Class="BlackJack.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="350"
                Background="#222222"
                CornerRadius="10"
                Padding="30">

            <StackPanel>

                <TextBlock Text="BLACKJACK"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="Gold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text=".exe"
                           FontSize="18"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Nickname"
                           Foreground="White"
                           FontSize="16"/>

                <TextBox Text="{Binding Username}"
                         Height="35"
                         Margin="0,5,0,15"
                         FontSize="16"/>

                <TextBlock Text="Passwort"
                           Foreground="White"
                           FontSize="16"/>

                <PasswordBox x:Name="PasswortBox"
                             Height="35"
                             Margin="0,5,0,25"
                             FontSize="16"
                             PasswordChanged="PasswortBox_PasswordChanged"/>

                <Button Content="Login"
                        Height="50"
                        FontSize="16"
                        Margin="0,0,0,10"
                        Command="{Binding LoginCommand}"/>

                <Button Content="Registrieren"
                        Height="50"
                        FontSize="16"
                        Command="{Binding RegisterCommand}"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>