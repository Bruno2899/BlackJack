<UserControl x:Class="BlackJack.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="550"
             Width="800"
             Background="Black">

	<Grid>

		<Border Width="320"
                Height="440"
                Background="Black"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

			<StackPanel>

				<TextBlock Text="BLACKJACK.exe"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

				<TextBlock Text="Nickname"
                           Foreground="White"/>

				<TextBox Text="{Binding Username}"
                         Height="35"
                         Margin="0,5,0,15"/>

				<TextBlock Text="Passwort"
                           Foreground="White"/>

				<PasswordBox x:Name="PasswortBox"
                             Height="35"
                             Margin="0,5,0,25"/>

				<Button Content="Login"
                        Height="40"
                        Command="{Binding LoginCommand}"/>

			</StackPanel>

		</Border>

	</Grid>

</UserControl>