<UserControl x:Class="BlackJack.Views.StatistikView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="450"
                Background="#222222"
                CornerRadius="10"
                Padding="30">

            <StackPanel>

                <TextBlock Text="STATISTIK"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="Gold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="{Binding SpieleAnzahl,
                    StringFormat= Spiele: {0}}"
                           FontSize="20"
                           Foreground="White"
                           Margin="0,8"/>

                <TextBlock Text="{Binding GesamtGewinn,
                    StringFormat= Gesamtgewinn: {0:F1} €}"
                           FontSize="20"
                           Foreground="LightGreen"
                           Margin="0,8"/>

                <TextBlock Text="{Binding WinRate,
                    StringFormat= Win Rate: {0:F1}%}"
                           FontSize="20"
                           Foreground="Gold"
                           Margin="0,8"/>

                <TextBlock Text="{Binding DurchschnittGewinn,
                    StringFormat= Durchschnitt: {0:F2} €}"
                           FontSize="20"
                           Foreground="White"
                           Margin="0,8"/>

                <TextBlock Text="{Binding GroessterGewinn,
                    StringFormat= Größter Gewinn: {0:F1} €}"
                           FontSize="20"
                           Foreground="LightGreen"
                           Margin="0,8"/>
                <TextBlock Text="TOP 5 SPIELER"
                           Foreground="Gold"
                           FontSize="24"
                           Margin="0,20,0,10"/>

                <TextBlock Text="{Binding Ranking}"
                           Foreground="White"
                           FontSize="18"/>

                <Button Content="Zurück"
                        Width="220"
                        Height="55"
                        FontSize="18"
                        Margin="0,30,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding BackCommand}"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>